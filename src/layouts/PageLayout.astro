---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import FloatingWhatsApp from "../components/layout/FloatingWhatsApp.astro";
import MobileBottomCTA from "../components/layout/MobileBottomCTA.astro";
import Hero from "../components/sections/Hero.astro";
import SectionRenderer from "../components/sections/SectionRenderer.astro";
import type { PageData } from "../data/types";

interface Props {
  page: PageData;
}

const { page } = Astro.props;
---

<BaseLayout page={page}>
  <Header />

  <main id="main-content">
    <Hero
      hero={page.hero}
      pageType={page.type}
      serviceType={page.serviceType}
      area={page.area}
      breadcrumb={page.breadcrumb}
    />

    <SectionRenderer sections={page.sections} />
  </main>

  <Footer />
  <FloatingWhatsApp ctaId="globalWhatsapp" />
  <MobileBottomCTA ctaId="globalWhatsapp" />
</BaseLayout>
