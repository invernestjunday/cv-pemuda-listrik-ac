---
import BaseLayout from "./BaseLayout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import FloatingWhatsApp from "../components/layout/FloatingWhatsApp.astro";
import MobileBottomCTA from "../components/layout/MobileBottomCTA.astro";
import type { PageData } from "../data/types";

interface Props {
  page: PageData;
}

const { page } = Astro.props;
---

<BaseLayout page={page}>
  <Header />

  <main id="main-content">
    <slot>
      <section class="section hero-skeleton">
        <div class="container hero-skeleton__content">
          {page.hero.badge && <p class="hero-skeleton__badge">{page.hero.badge}</p>}
          <h1>{page.hero.h1}</h1>
          <p>{page.hero.subheadline}</p>
        </div>
      </section>
    </slot>
  </main>

  <Footer />
  <FloatingWhatsApp ctaId="globalWhatsapp" />
  <MobileBottomCTA ctaId="globalWhatsapp" />
</BaseLayout>
