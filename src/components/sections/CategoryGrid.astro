---
import type { CategoryItem, ServiceType } from "../../data/types";
import SectionHeader from "../ui/SectionHeader.astro";
import CategoryCard from "../cards/CategoryCard.astro";

interface Props {
  id?: string;
  title: string;
  description?: string;
  items: CategoryItem[];
  serviceType?: ServiceType;
}

const { id, title, description, items, serviceType } = Astro.props;
---

<section class="section section--white" id={id}>
  <div class="container">
    <SectionHeader title={title} description={description} />
    <div class="grid grid--cards">
      {items.map((item) => <CategoryCard item={item} serviceType={serviceType} />)}
    </div>
  </div>
</section>
