---
import type { LinkItem } from "../../data/types";
import WhatsAppButton from "../ui/WhatsAppButton.astro";
import ButtonLink from "../ui/ButtonLink.astro";

interface Props {
  id?: string;
  title: string;
  description?: string;
  primaryCtaId: string;
  secondaryLink?: LinkItem;
}

const { id, title, description, primaryCtaId, secondaryLink } = Astro.props;
---

<section class="section section--white" id={id}>
  <div class="container">
    <div class="cta-card">
      <div>
        <h2 class="cta-card__title">{title}</h2>
        {description && <p class="cta-card__description">{description}</p>}
      </div>

      <div class="cta-card__actions">
        <WhatsAppButton ctaId={primaryCtaId as any} position="cta-final" />
        {secondaryLink && (
          <ButtonLink
            href={secondaryLink.href}
            label={secondaryLink.label}
            variant="secondary"
          />
        )}
      </div>
    </div>
  </div>
</section>
