---
import type { LinkItem } from "../../data/types";
import SectionHeader from "../ui/SectionHeader.astro";

interface Props {
  id?: string;
  title: string;
  description?: string;
  links: LinkItem[];
}

const { id, title, description, links } = Astro.props;
---

<section class="section section--white" id={id}>
  <div class="container">
    <SectionHeader title={title} description={description} />

    <div class="internal-links">
      {links.map((link) => (
        <a href={link.href} class="internal-links__item">{link.label}</a>
      ))}
    </div>
  </div>
</section>
