---
import type { CardItem } from "../../data/types";
import SectionHeader from "../ui/SectionHeader.astro";
import TrustCard from "../cards/TrustCard.astro";

interface Props {
  id?: string;
  title: string;
  description?: string;
  items: CardItem[];
}

const { id, title, description, items } = Astro.props;
---

<section class="section section--white" id={id}>
  <div class="container">
    <SectionHeader title={title} description={description} />
    <div class="grid grid--cards">
      {items.map((item) => <TrustCard item={item} />)}
    </div>
  </div>
</section>
