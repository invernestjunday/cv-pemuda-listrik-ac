---
import { site } from "../../data/site";
import { mainNav } from "../../data/navigation";
import WhatsAppButton from "../ui/WhatsAppButton.astro";
import MobileMenu from "./MobileMenu.astro";
import { withBase } from "../../utils/link";
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href={withBase("/")} class="site-brand" aria-label="CV Pemuda Listrik & AC - Beranda">
      <img
        class="site-brand__logo"
        src={withBase(site.logo)}
        alt=""
        width="44"
        height="44"
        loading="eager"
      />
      <span class="site-brand__text">CV Pemuda Listrik & AC</span>
    </a>

    <nav class="desktop-nav" aria-label="Navigasi utama">
      {mainNav.map((item) => {
        const dropdownId = `dropdown-${item.label.toLowerCase().replace(/\s+/g, "-")}`;

        return item.children ? (
          <div class="nav-dropdown" data-dropdown>
            <button
              type="button"
              class="nav-dropdown__trigger"
              aria-expanded="false"
              aria-controls={dropdownId}
            >
              {item.label}
            </button>
            <div id={dropdownId} class="nav-dropdown__panel" hidden>
              {item.children.map((child) => (
                <a href={withBase(child.href)}>{child.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={withBase(item.href)}>{item.label}</a>
        );
      })}
    </nav>

    <div class="desktop-cta">
      <WhatsAppButton ctaId="globalWhatsapp" position="header" />
    </div>

    <div class="mobile-actions">
      <WhatsAppButton
        ctaId="globalWhatsapp"
        position="header"
        className="btn--compact"
        labelOverride="WA"
      />

      <button
        type="button"
        class="mobile-menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Buka menu navigasi"
      >
        <span aria-hidden="true">☰</span>
      </button>
    </div>
  </div>

  <MobileMenu />
</header>
