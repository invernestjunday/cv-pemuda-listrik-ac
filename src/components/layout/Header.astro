---
import { mainNav } from "../../data/navigation";
import WhatsAppButton from "../ui/WhatsAppButton.astro";
import MobileMenu from "./MobileMenu.astro";
---

<header class="site-header">
  <div class="container site-header__inner">
    <a href="/" class="site-brand" aria-label="CV Pemuda Listrik & AC - Beranda">
      CV Pemuda Listrik & AC
    </a>

    <nav class="desktop-nav" aria-label="Navigasi utama">
      {mainNav.map((item) => (
        item.children ? (
          <div class="nav-dropdown">
            <button
              type="button"
              class="nav-dropdown__trigger"
              aria-expanded="false"
            >
              {item.label}
            </button>
            <div class="nav-dropdown__panel">
              {item.children.map((child) => (
                <a href={child.href}>{child.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a href={item.href}>{item.label}</a>
        )
      ))}
    </nav>

    <div class="desktop-cta">
      <WhatsAppButton ctaId="globalWhatsapp" position="header" />
    </div>

    <div class="mobile-actions">
      <WhatsAppButton
        ctaId="globalWhatsapp"
        position="header"
        className="btn--compact"
        labelOverride="WA"
      />

      <button
        type="button"
        class="mobile-menu-toggle"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Buka menu navigasi"
      >
        <span aria-hidden="true">☰</span>
      </button>
    </div>
  </div>

  <MobileMenu />
</header>

<script>
  const toggle = document.querySelector(".mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");

  if (toggle && menu) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";

      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute(
        "aria-label",
        isOpen ? "Buka menu navigasi" : "Tutup menu navigasi"
      );

      menu.hidden = isOpen;
    });
  }
</script>
